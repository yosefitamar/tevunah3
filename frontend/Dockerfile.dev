FROM node:22-alpine

WORKDIR /app

RUN apk add --no-cache libc6-compat

ENV NEXT_TELEMETRY_DISABLED=1 \
    WATCHPACK_POLLING=true \
    CHOKIDAR_USEPOLLING=true

EXPOSE 3000

# Em dev, o código e o package.json vêm via bind mount (./frontend:/app) e o
# node_modules é um volume nomeado que sombreia o da imagem. Por isso não adianta
# instalar deps no build: o volume persiste e nunca reinstala ao adicionar pacotes.
# A solução é instalar no boot — assim `./tevunah up`/`setup` sempre reconcilia o
# volume com o package.json/lockfile atuais, e adicionar uma dependência nunca mais
# exige rebuild manual nem "module not found".
CMD ["sh", "-c", "npm install && npm run dev"]
