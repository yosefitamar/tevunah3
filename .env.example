# Ambiente de execução: development | production
APP_ENV=development

# Portas expostas no host
BACKEND_PORT=8080
FRONTEND_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379

# Postgres — credenciais do superuser (usado pelas migrations)
POSTGRES_USER=tevunah
POSTGRES_PASSWORD=tevunah
POSTGRES_DB=tevunah

# Roles separados criados pelo init script na primeira subida do Postgres
APP_DB_USER=tevunah_app
APP_DB_PASSWORD=tevunah_app
AUDIT_DB_USER=tevunah_audit_writer
AUDIT_DB_PASSWORD=tevunah_audit_writer

# Admin de desenvolvimento — criado por `./tevunah seed:dev` quando APP_ENV=development.
# Em produção este bloco NÃO é usado; use `./tevunah admin:create`.
DEV_ADMIN_EMAIL=admin@tevunah.local
DEV_ADMIN_NAME=Administrador Dev
DEV_ADMIN_PASSWORD=tevunah-dev-12345
