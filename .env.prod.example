# Tevunah — variáveis de ambiente de produção.
# Copie para .env.prod e ajuste TODOS os valores antes de subir.
#   cp .env.prod.example .env.prod && nano .env.prod
# Gere senhas com: openssl rand -base64 32

# ─── Postgres superuser (usado por init scripts e migrations) ───
POSTGRES_USER=tevunah
POSTGRES_PASSWORD=CHANGE_ME_postgres_super
POSTGRES_DB=tevunah

# ─── Postgres roles de aplicação (criados pelo init script 01_roles.sh) ───
APP_DB_USER=tevunah_app
APP_DB_PASSWORD=CHANGE_ME_app_role

AUDIT_DB_USER=tevunah_audit_writer
AUDIT_DB_PASSWORD=CHANGE_ME_audit_role

# ─── App ───
SESSION_IDLE_MINUTES=15

# ─── Bind do frontend no host ───
# Cloudflared aponta pra este host:porta. Use 0.0.0.0 se o tunnel vier de
# outra CT/host; 127.0.0.1 se o cloudflared roda na mesma máquina.
FRONTEND_BIND=0.0.0.0
FRONTEND_PORT=3000
